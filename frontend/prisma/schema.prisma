generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  
  accounts      Account[]
  sessions      Session[]
  resumes       Resume[]
  coverLetters  CoverLetter[]
  candidates    Candidate[]
  
  subscriptionTier String @default("FREE")
  stripeCustomerId String? @unique
  role             String  @default("STUDENT")
  aiMode           String  @default("pro")
  discovery        Boolean @default(true)
  isGhostMode      Boolean @default(false)
  lastGhostScan    DateTime?
  
  linkedinUrl      String?
  naukriUrl        String?
  indeedUrl        String?
  internshalaUrl   String?
  targetJobRole    String?
  
  jobMatches       JobMatch[]
  interviews       InterviewSession[]
}

model JobMatch {
  id          String   @id @default(cuid())
  userId      String
  role        String
  company     String
  score       Int
  summary     String?
  sourceUrl   String?
  status      String   @default("UNREAD")
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Resume {
  id          String   @id @default(cuid())
  userId      String
  content     String
  atsScore    Int?
  keywordGaps String?
  fileName    String?
  jdSimilarity Float?
  jdGaps      String?
  graphData   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CoverLetter {
  id          String   @id @default(cuid())
  userId      String
  targetJob   String
  content     String
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Candidate {
  id          String   @id @default(cuid())
  recruiterId String
  name        String?
  email       String?
  phone       String?
  college     String?
  githubUrl   String?
  similarity  Int
  resumeFile  Bytes?
  resumeName  String?
  status      String   @default("SELECTED")
  createdAt   DateTime @default(now())

  recruiter   User     @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
}

model InterviewSession {
  id              String   @id @default(cuid())
  userId          String
  targetRole      String
  companyName     String?
  jdText          String?
  resumeText      String?
  overallVerdict  String?
  overallJustification String?
  status          String   @default("IN_PROGRESS")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages        InterviewMessage[]
}

model InterviewMessage {
  id              String   @id @default(cuid())
  sessionId       String
  role            String   // 'assistant' or 'user'
  content         String
  analysis        String?  // JSON string of live analysis metrics
  createdAt       DateTime @default(now())
  
  session         InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}
