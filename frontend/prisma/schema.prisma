generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  
  accounts      Account[]
  sessions      Session[]
  resumes       Resume[]
  coverLetters  CoverLetter[]
  candidates    Candidate[]
  
  role             String  @default("STUDENT")
  aiMode           String  @default("pro")
  discovery        Boolean @default(true)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Resume {
  id          String   @id @default(cuid())
  userId      String
  content     String
  atsScore    Int?
  keywordGaps String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CoverLetter {
  id          String   @id @default(cuid())
  userId      String
  targetJob   String
  content     String
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Candidate {
  id          String   @id @default(cuid())
  recruiterId String
  name        String?
  email       String?
  phone       String?
  college     String?
  githubUrl   String?
  similarity  Int
  resumeFile  Bytes?
  resumeName  String?
  status      String   @default("SELECTED")
  createdAt   DateTime @default(now())

  recruiter   User     @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
}
